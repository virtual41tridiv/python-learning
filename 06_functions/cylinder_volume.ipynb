   "source": [
    "def find_volume_cyclinder(radius, height):\n",
    "    print(\"radius:\", radius)\n",
    "    print(\"height:\", height)\n",
    "    pi =3.14\n",
    "    volume = pi * radius**2 * height\n",
    "    return volume\n",
    "\n",
    "r= 10\n",
    "h= 13\n",
    "\n",
    "v= find_volume_cyclinder(r, h)\n",
    "print(\"Volume of the cyclinder:\", v)"
   ]
  }
