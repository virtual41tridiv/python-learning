    "def sum_all_num(*args):\n",
    "    total=0\n",
    "    for num in args:\n",
    "        total += num\n",
    "    return total\n",
    "\n",
    "total = sum_all_num(1, 2, 3, 4, 5)\n",
    "print(total)"
